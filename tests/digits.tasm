; print digits of 9274 on four separate lines
; using only DIV and MOD, unrolled
; expected output:
; 9
; 2
; 7
; 4

        ; extract thousands digit: 9274 / 1000 = 9
        PUSH 9274       ; [9274]
        PUSH 1000       ; [9274, 1000]
        DIV             ; [9]
        PRINT           ; []

        ; extract hundreds digit: (9274 / 100) % 10 = 2
        PUSH 9274       ; [9274]
        PUSH 100        ; [9274, 100]
        DIV             ; [92]
        PUSH 10         ; [92, 10]
        MOD             ; [2]
        PRINT           ; []

        ; extract tens digit: (9274 / 10) % 10 = 7
        PUSH 9274       ; [9274]
        PUSH 10         ; [9274, 10]
        DIV             ; [927]
        PUSH 10         ; [927, 10]
        MOD             ; [7]
        PRINT           ; []

        ; extract units digit: 9274 % 10 = 4
        PUSH 9274       ; [9274]
        PUSH 10         ; [9274, 10]
        MOD             ; [4]
        PRINT           ; []

        HALT
